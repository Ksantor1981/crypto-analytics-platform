# Database
POSTGRES_DB=crypto_analytics
POSTGRES_USER=crypto_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Backend (Docker: хост postgres; пароль Redis в URL после :)
DATABASE_URL=postgresql://crypto_user:CHANGE_ME_strong_password_here@postgres:5432/crypto_analytics
REDIS_PASSWORD=CHANGE_ME_redis_password_same_as_in_url
REDIS_URL=redis://:CHANGE_ME_redis_password_same_as_in_url@redis:6379/0
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
TRADING_ENCRYPTION_KEY=CHANGE_ME_32_byte_encryption_key

# Environment
ENVIRONMENT=production
DEBUG=false

# ML Service
ML_SERVICE_URL=http://ml-service:8001

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Telegram (optional, for private channels)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Monitoring (Sentry — free at sentry.io)
SENTRY_DSN=https://your-key@sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# Frontend (NEXT_PUBLIC_API_URL — база без суффикса /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ML training (train_from_db.py) — см. docs/ML_DATA_INTEGRITY_ROADMAP.md
# ML_AUGMENT_TARGET=0
# ML_SYNTHETIC_FALLBACK=1
# ML_INDICATOR_TIMEFRAME=1d
# ML_STRICT_DATA_QUALITY=1
