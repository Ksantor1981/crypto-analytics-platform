# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Security - REQUIRED
SECRET_KEY=your-super-secret-jwt-key-here-minimum-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database - REQUIRED (PostgreSQL)
DATABASE_URL=postgresql://crypto_user:crypto_password@localhost:5432/crypto_analytics

# SQLite (dev): USE_SQLITE=true — БД в backend/crypto_analytics.db
# USE_SQLITE=true

# Redis (dev stack uses requirepass; keep both variants documented)
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
AUTH_RATE_LIMIT_REQUESTS=5
AUTH_RATE_LIMIT_WINDOW=900

# External APIs
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION_NAME=session_name

# ML Service
ML_SERVICE_URL=http://ml-service:8001
# ML_MODEL_VERSION=v6  # optional: A/B by model version
# ML_HTTP_RETRIES=2
# ML_CIRCUIT_FAILURE_THRESHOLD=5
# ML_CIRCUIT_OPEN_SECONDS=60
# READINESS_REQUIRE_REDIS=false
# READINESS_REQUIRE_ML=false

# Canonical data plane: dual-write в raw_events (Telegram web). Только после alembic upgrade.
# SHADOW_PIPELINE_ENABLED=false
# Telethon collect: вкладывать полный снимок MTProto в raw_payload.mtproto (bytes → base64)
# SHADOW_TELETHON_FULL_MTPROTO=true
# Celery beat (04:15 UTC): Telethon collect-all по всем активным TG-каналам — только при session на воркере
# CELERY_TELETHON_COLLECT_ENABLED=false
# TELETHON_COLLECT_DAYS_BACK=7
# CELERY_TELETHON_COLLECT_LOCK_TTL=7200
# EXTRACTION_PIPELINE_ENABLED=false
# (включает также admin materialize → normalized_signals при decision=signal + PARSED)
# Каталог execution_models (3 модели по умолчанию) — миграция l6f7a8b9c0d1; API: GET /api/v1/admin/execution-models
# Исходы: signal_outcomes — миграция m7b8c9d0e1f2; слоты PENDING:
# POST /api/v1/admin/signal-outcomes/ensure/{normalized_signal_id}
# POST /api/v1/admin/signal-outcomes/ensure-for-raw-event/{raw_event_id}
# OUTCOME_SLOTS_AUTO_ENSURE=false
# При открытии карточки Review (GET .../review-labels/raw-events/{id}) — дозаполнить слоты
# OUTCOME_SLOTS_AUTO_ENSURE_ON_REVIEW_DETAIL=false
# Пересчёт outcomes по свечам (DB market_candles приоритетно, иначе CoinGecko OHLC)
# OUTCOME_RECALC_ENABLED=false
# OUTCOME_RECALC_LOOKAHEAD_DAYS=14
# OUTCOME_RECALC_TIMEFRAME=1h
# OUTCOME_RECALC_BATCH_LIMIT=50
# market_on_publish: close | open | hl2 | ohlc4
# OUTCOME_MOP_REFERENCE=close
# На свече с одновременным SL и TP: true = сначала SL
# OUTCOME_INTRABAR_SL_BEFORE_TP=true
# Celery: блокировка задачи recalculate_canonical_signal_outcomes (сек)
# CELERY_OUTCOME_RECALC_LOCK_TTL=900

# Collection (C1: without Telegram — only Reddit/seed)
# COLLECT_TELEGRAM=false
# В одном прогоне run_collection: после Telegram подтянуть Reddit
# COLLECT_REDDIT_IN_RUN_COLLECTION=true
# Scheduler mode:
# - asyncio: background loops inside backend process
# - celery: rely on celery beat/worker only (recommended for production)
# SCHEDULER_MODE=celery
# Celery: Redis lock TTL (сек) — защита от дублей при нескольких воркерах (см. app/celery_worker.py)
# CELERY_COLLECT_LOCK_TTL=1800
# CELERY_CHECK_SIGNALS_LOCK_TTL=1700
# Лимит постов t.me/s: base + (channel.priority-1)*step, max cap
# TELEGRAM_POSTS_BASE_LIMIT=20
# TELEGRAM_POSTS_PRIORITY_STEP=5
# TELEGRAM_POSTS_MAX_LIMIT=80
# OCR fallback (t.me/s image posts)
# OCR_TELEGRAM_ENABLED=true
# OCR_TELEGRAM_MAX_IMAGES_PER_POST=1
# OCR_TELEGRAM_SLEEP_MS=250
# OCR_MIN_CHARS=25
# OCR_CACHE_TTL_SECONDS=86400
# OCR_CACHE_MAX_ITEMS=2000
# OCR_MAX_IMAGES_PER_CHANNEL=120
# OCR_LANGS=en,ru
# OCR_PREPROCESS=true
# OCR_PREPROCESS_SCALE=2.0
# OCR_PREPROCESS_MAX_VARIANTS=6
# OCR_DEBUG_PREPROCESS=false
# STORE_RAW_TELEGRAM_SIGNALS=true
# RAW_MEDIA_PROCESS_LIMIT=200
# RAW_MEDIA_PROCESS_MAX_ATTEMPTS=5
# COLLECT_LOG_PARSE_FUNNEL=true
# Docker: интервал сбора (сек), без демо-каналов при старте
# COLLECTION_INTERVAL_SECONDS=180
# AUTO_SEED_DEMO_CHANNELS=false
# Production: доверенные Host (через запятую), не URL
# TRUSTED_HOSTS=api.example.com,example.com

# CORS (production): JSON array for Pydantic, e.g.
# BACKEND_CORS_ORIGINS=["https://app.example.com"]

# Trading worker (required when running trading-worker)
TRADING_ENCRYPTION_KEY=change_me_32_chars_min

# Stripe (Optional)
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Enables deterministic "fake Stripe" checkout for CI/E2E.
# STRIPE_MOCK_MODE=true allows end-to-end subscription flow without real Stripe keys.
# STRIPE_MOCK_MODE=false
STRIPE_MOCK_MODE=false

# Email Configuration (Optional)
# SMTP Settings
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your_email@gmail.com
EMAIL_SMTP_PASSWORD=your_app_password
EMAIL_FROM_ADDRESS=noreply@crypto-analytics.com
EMAIL_FROM_NAME=Crypto Analytics Platform
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# SendGrid Alternative (Optional)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@crypto-analytics.com
SENDGRID_FROM_NAME=Crypto Analytics Platform 